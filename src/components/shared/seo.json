{
  "collectionName": "components_shared_seos",
  "info": {
    "name": "Seo",
    "icon": "search",
    "displayName": "Seo",
    "description": "Per-page SEO meta and social sharing fields."
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "required": true
    },
    "metaDescription": {
      "type": "text",
      "required": true,
      "maxLength": 160
    },
    "shareImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "canonicalUrl": {
      "type": "string",
      "required": false
    },
    "noindex": {
      "type": "boolean",
      "required": false,
      "default": false
    }
  }
}
